# Local development (backend run directly, without Docker)
ENVIRONMENT=development
SECRET_KEY=generate-a-long-random-string
# PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://durakhshon:password@localhost:5432/durakhshon
# SQLite fallback for quick local development:
DATABASE_URL=sqlite:///./durakhshon_dev.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# sessions
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_DAYS=1
REFRESH_TOKEN_REMEMBER_DAYS=14
# demo data (local dev only)
SEED_DEMO=true
SEED_DEMO_PASSWORD=Demo1234!
# backups (off locally; the standalone scripts/ tools still work on demand)
BACKUP_ENABLED=false
BACKUP_DIR=./backups
