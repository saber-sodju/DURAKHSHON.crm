# ---- Docker Compose environment ----
# Copy to .env and fill in real values. NEVER commit .env to git.

# PostgreSQL
POSTGRES_USER=durakhshon
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=durakhshon

# Backend
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
ENVIRONMENT=production
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
# Set to true when serving over HTTPS
COOKIE_SECURE=false
# "lax" for same-origin deploys (docker-compose nginx proxy). Use "none" (requires
# COOKIE_SECURE=true) only if frontend and backend are served from different origins.
COOKIE_SAMESITE=lax

# Login sessions
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_DAYS=1            # "remember me" off
REFRESH_TOKEN_REMEMBER_DAYS=14 # "remember me" on

# Demo data — MUST be false in production. When true, `python -m app.seed`
# creates the demo users/students; the app also refuses to start in production
# if this is true.
SEED_DEMO=false
SEED_DEMO_PASSWORD=Demo1234!   # only used when SEED_DEMO=true

# Automatic server-side backups (enable on the always-on host).
# BACKUP_DIR should be a mounted volume so dumps survive redeploys.
BACKUP_ENABLED=false
BACKUP_DIR=/data/backups
